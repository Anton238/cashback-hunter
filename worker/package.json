{
  "name": "cashback-hunter-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute cashback-hunter --file=src/db/schema.sql",
    "db:init:remote": "wrangler d1 execute cashback-hunter --file=src/db/schema.sql --remote",
    "db:seed": "wrangler d1 execute cashback-hunter --file=src/db/seed.sql",
    "db:seed:remote": "wrangler d1 execute cashback-hunter --file=src/db/seed.sql --remote"
  },
  "dependencies": {
    "@block65/webcrypto-web-push": "^1.0.2",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250307.0",
    "typescript": "^5.8.2",
    "wrangler": "^4"
  }
}
